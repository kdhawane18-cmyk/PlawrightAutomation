{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "types": ["@playwright/test", "node"]
  },
  "include": ["**/*.ts", "**/*.js", "pageobject_ts"],
  "exclude": ["node_modules"]
}
